# Guard BigQuery commands.
# This policy language only supports command-prefix matching,
# so query text itself cannot be inspected reliably.

# Block destructive `bq rm` operations.
prefix_rule(
    pattern = ["bq", "rm"],
    decision = "forbidden",
    justification = "bq rm is blocked. Destructive BigQuery operations require manual confirmation outside the agent.",
    match = [
        "bq rm -t project:dataset.table",
        "bq rm -f -r project:dataset",
    ],
    not_match = [
        "bq ls",
        "bq query 'SELECT 1'",
    ],
)

# Require explicit user approval for all bq query invocations.
prefix_rule(
    pattern = ["bq", "query"],
    decision = "forbidden",
    justification = "bq query is blocked in agent execution. Run manually outside Codex after explicit human review.",
    match = [
        "bq query --use_legacy_sql=false 'SELECT 1'",
        "bq query --maximum_bytes_billed=10737418240 'SELECT * FROM dataset.table LIMIT 10'",
    ],
    not_match = [
        "bq ls",
        "bq show project:dataset.table",
    ],
)
