# Mask curl's default user-agent string
user-agent = "Mozilla/5.0 (Windows NT 6.1; rv:45.0) Gecko/20100101 Firefox/45.0"

# Automatically set the Referer header on redirects
referer = ";auto"

# Abort if connection isn't established within 10 seconds
connect-timeout = 10

# Show a progress bar instead of the statistics meter
progress-bar

# Abort if transfer takes longer than 5 minutes
max-time = 300

# Print detailed request/response information
verbose

# Show error messages instead of failing silently
show-error

# Set file timestamps to match the remote file
remote-time

# Prefer IPv4 over IPv6
ipv4

# Fail on server errors (4xx/5xx) rather than silently succeeding
fail

# Prevent protocol downgrades on redirects
proto-redir = https
