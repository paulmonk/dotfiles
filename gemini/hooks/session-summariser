#!/usr/bin/env python3
"""SessionEnd hook: summarise a Gemini CLI session into a memory episode.

Reads the SessionEnd hook JSON from stdin (containing cwd, session_id,
transcript_path), parses the session transcript, calls Gemini Flash
for summarisation, and writes an episode .md file into the Obsidian vault.

Forks a child process so the hook returns immediately without
blocking session close.
"""

from __future__ import annotations

import datetime as dt
import json
import logging
import os
import re
import shutil
import subprocess
import sys
from collections import Counter
from pathlib import Path
from typing import Any, Final

MEMORY_DIR: Final[Path] = Path.home() / "Documents" / "Personal" / "3-Gemini-Sessions"
LOG_DIR: Final[Path] = Path.home() / ".gemini" / "logs" / "memory-episodes"

# Truncation limit for dialogue sent to the summariser.
MAX_DIALOGUE_CHARS: Final[int] = 80_000

log = logging.getLogger(__name__)


def setup_logging() -> None:
    """Configure file-based logging, falling back to stderr."""
    try:
        LOG_DIR.mkdir(parents=True, exist_ok=True)
        logging.basicConfig(
            filename=str(LOG_DIR / "summariser.log"),
            format="[%(asctime)s] %(message)s",
            datefmt="%Y-%m-%dT%H:%M:%S%z",
            level=logging.INFO,
        )
    except OSError:
        logging.basicConfig(
            stream=sys.stderr,
            format="[%(asctime)s] %(message)s",
            datefmt="%Y-%m-%dT%H:%M:%S%z",
            level=logging.INFO,
        )
        log.warning("Could not create log directory %s, logging to stderr", LOG_DIR)


def parse_session(path: Path) -> tuple[str, Counter[str]]:
    """Extract dialogue lines and tool use counts from a session file.

    Args:
        path: Path to the Gemini session JSON file.

    Returns:
        Tuple of (dialogue_text, tool_counter).
    """
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError) as exc:
        log.warning("Failed to read session file %s: %s", path.name, exc)
        return "", Counter()

    messages = data.get("messages", [])
    lines: list[str] = []
    tools: Counter[str] = Counter()

    for msg in messages:
        msg_type = msg.get("type")

        if msg_type == "user":
            content = msg.get("content", [])
            if isinstance(content, list):
                for item in content:
                    text = item.get("text", "") if isinstance(item, dict) else ""
                    if text.strip():
                        lines.append(f"Human: {text.strip()}")
            elif isinstance(content, str) and content.strip():
                lines.append(f"Human: {content.strip()}")

        elif msg_type == "gemini":
            content = msg.get("content", "")
            if isinstance(content, str) and content.strip():
                lines.append(f"Assistant: {content.strip()}")

            for tc in msg.get("toolCalls", []):
                name = tc.get("name", "unknown")
                tools[name] += 1

    return "\n".join(lines), tools


def build_prompt(dialogue: str, *, tools: Counter[str]) -> str:
    """Assemble the summarisation prompt.

    Args:
        dialogue: Extracted human/assistant dialogue text.
        tools: Counter of tool names used in the session.

    Returns:
        Complete prompt string.
    """
    truncated = dialogue[:MAX_DIALOGUE_CHARS]

    parts = [
        "Summarise this Gemini CLI conversation concisely.",
        "",
        "Start your response with a title line in exactly this format:",
        "Title: <short descriptive title, max 60 characters>",
        "",
        "Then provide the structured summary:",
        "",
        "## Goals",
        "- Bullet points of what the user wanted to achieve.",
        "",
        "## Decisions",
        "- Bullet points of key choices made and their rationale.",
        "",
        "## Outcomes",
        "- Bullet points of what was accomplished and what remains.",
        "",
        "Use markdown bullet points (- ) for all items under each heading. "
        "Do not write plain paragraphs. Keep it under 300 words. "
        "Focus on decisions and rationale, not individual tool calls "
        "or code. Do not use emojis.",
    ]

    if tools:
        top_tools = ", ".join(f"{name} ({count})" for name, count in tools.most_common(10))
        parts.append("")
        parts.append(f"Tools used: {top_tools}")

    parts.append("")
    parts.append("<conversation>")
    parts.append(truncated)
    parts.append("</conversation>")

    return "\n".join(parts)


def call_gemini_flash(prompt: str) -> str:
    """Send a prompt to Gemini Flash and return the response.

    Args:
        prompt: The full prompt text.

    Returns:
        Model response text, or empty string on failure.
    """
    gemini_executable = shutil.which("gemini")
    if gemini_executable is None:
        log.warning("gemini not available on PATH for session summarisation")
        return ""

    env = {**os.environ, "_GEMINI_SUMMARISER": "1"}
    try:
        result = subprocess.run(  # noqa: S603 - calling gemini CLI with our own prompt
            [
                gemini_executable,
                "-p",
                prompt,
                "--model",
                "flash",
                "--sandbox",
                "false",
                "--allowed-mcp-server-names",
                "",
            ],
            capture_output=True,
            text=True,
            timeout=120,
            check=False,
            env=env,
        )
    except subprocess.TimeoutExpired:
        log.warning("gemini timed out after 120s for summarisation")
        return ""
    except OSError as exc:
        log.warning("gemini not available: %s", exc)
        return ""

    if result.returncode != 0:
        log.warning("gemini exited %d: %s", result.returncode, result.stderr[:500])
        return ""

    output = result.stdout.strip()
    if not output:
        log.warning("gemini returned empty stdout for session summarisation")
        return ""

    # Non-interactive mode can leak debug/hook lines into stdout.
    noise_prefixes = (
        "Created execution plan",
        "Expanding hook command",
        "Hook execution for",
        "Loaded cached credentials",
    )
    cleaned = [line for line in output.splitlines() if not line.startswith(noise_prefixes)]
    return "\n".join(cleaned).strip()


def slugify(text: str) -> str:
    """Convert text to a lowercase, dash-separated filename slug."""
    slug = text.lower()
    slug = slug.replace("\u2018", "").replace("\u2019", "")
    slug = slug.replace("\u201c", "").replace("\u201d", "")
    slug = slug.replace("\u2013", "-").replace("\u2014", "-")
    slug = re.sub(r"[/\\:*?\"<>|'`,.()\[\]{}!;@#]", "", slug)
    slug = re.sub(r"[\s_]+", "-", slug)
    slug = re.sub(r"-{2,}", "-", slug)
    return slug.strip("-")


def parse_title(summary: str) -> tuple[str, str]:
    """Extract a Title: line from the start of the summary.

    Args:
        summary: Raw summary text from the LLM.

    Returns:
        Tuple of (title, remaining_summary).
    """
    match = re.match(r"^Title:\s*(.+)", summary)
    if not match:
        return "", summary
    title = match.group(1).strip()
    if len(title) > 80:
        title = title[:80].rsplit(" ", 1)[0]
    rest = summary[match.end() :].lstrip("\n")
    return title, rest


PROJECTS_ROOT: Final[Path] = Path.home() / "projects"


def derive_project(cwd: str) -> str:
    """Derive a project name from session cwd.

    For paths under ~/projects, returns up to two components
    (org/repo) so episodes group by organisation. Git worktrees
    are resolved to their main repo first via the .git file.

    Args:
        cwd: Working directory from the session.

    Returns:
        Project path string, or "_unknown" for unresolvable cases.
    """
    if not cwd or cwd == "/":
        return "_unknown"
    path = Path(cwd)

    # Resolve worktrees to their main repo root.
    git_marker = path / ".git"
    if git_marker.is_file():
        try:
            text = git_marker.read_text().strip()
            gitdir = text.removeprefix("gitdir:").strip()
            if "/.git/" in gitdir:
                path = Path(gitdir.split("/.git/")[0])
        except OSError as exc:
            log.warning("Could not read %s to resolve worktree: %s", git_marker, exc)

    try:
        rel = path.relative_to(PROJECTS_ROOT)
        parts = rel.parts[:2]
        if parts:
            return str(Path(*parts))
    except ValueError:
        pass

    return path.name or "_unknown"


def write_episode(
    summary: str,
    *,
    title: str,
    project: str,
    cwd: str,
    session_id: str,
    tools: Counter[str],
    now: dt.datetime,
) -> Path:
    """Write an episode markdown file with enriched frontmatter.

    Args:
        summary: The model-generated summary text.
        title: Short descriptive title for the episode.
        project: Project name derived from cwd.
        cwd: Working directory of the session.
        session_id: Session identifier.
        tools: Counter of tool names used.
        now: Timestamp for the episode.

    Returns:
        Path to the written episode file.
    """
    project_dir = MEMORY_DIR / project
    project_dir.mkdir(parents=True, exist_ok=True)

    date_str = now.strftime("%Y-%m-%d")
    timestamp = now.strftime("%Y-%m-%dT%H:%M:%SZ")
    short_id = session_id[:7]
    heading = title or f"Conversation: {project}"

    slug = slugify(heading)
    if len(slug) > 80:
        slug = slug[:80].rsplit("-", 1)[0]
    filename = f"{date_str}-{slug}.md"

    summary_file = project_dir / filename
    counter = 2
    while summary_file.exists():
        summary_file = project_dir / f"{date_str}-{slug}-{counter}.md"
        counter += 1

    fm_lines = [
        "---",
        f'title: "{heading}"',
        f"date: {timestamp}",
        f"project: {project}",
        f"directory: {cwd}",
        f"session_id: {short_id}",
    ]
    if tools:
        tool_names = sorted(tools)
        fm_lines.append(f"tools: [{', '.join(tool_names)}]")
    fm_lines.append("type: conversation")
    fm_lines.append("agent: gemini")
    fm_lines.append("---")

    content = "\n".join(fm_lines) + f"\n\n# {heading}\n\n{summary}\n"
    summary_file.write_text(content)
    return summary_file


def _run_pipeline(hook_input: dict[str, Any]) -> None:
    """Run the summarisation pipeline from parsed hook input."""
    cwd = hook_input.get("cwd", "")
    session_id = hook_input.get("session_id", "")
    transcript_path = hook_input.get("transcript_path", "")

    if not cwd or not session_id:
        log.info("Missing cwd or session_id in hook input, skipping")
        return

    if not transcript_path:
        log.info("No transcript_path for %s, skipping", session_id[:7])
        return

    session_file = Path(transcript_path)
    if not session_file.is_file():
        log.info("Transcript file not found at %s, skipping", transcript_path)
        return

    dialogue, tools = parse_session(session_file)
    if not dialogue:
        log.info("No dialogue in %s, skipping", session_id[:7])
        return

    prompt = build_prompt(dialogue, tools=tools)
    summary = call_gemini_flash(prompt)
    if not summary:
        log.warning("Summarisation returned empty for %s", session_id[:7])
        return

    title, summary = parse_title(summary)
    now = dt.datetime.now(dt.UTC)
    project = derive_project(cwd)

    episode = write_episode(
        summary,
        title=title,
        project=project,
        cwd=cwd,
        session_id=session_id,
        tools=tools,
        now=now,
    )
    log.info("Wrote episode %s", episode.name)


if __name__ == "__main__":
    # Guard against recursive invocation (our gemini call fires SessionEnd).
    if os.environ.get("_GEMINI_SUMMARISER"):
        sys.exit(0)

    # Read all input before forking (stdin closes with parent).
    raw = sys.stdin.read().strip()
    if not raw:
        sys.exit(0)

    try:
        hook_input = json.loads(raw)
    except json.JSONDecodeError as exc:
        sys.stderr.write(f"[session-summariser] invalid JSON from hook: {exc}\n")
        sys.exit(0)

    if not hook_input.get("session_id"):
        sys.exit(0)

    # Only summarise on explicit exit, not clear/logout.
    reason = hook_input.get("reason", "")
    if reason not in ("exit", "other", ""):
        sys.exit(0)

    # Ensure brew binaries are on PATH for the child process.
    os.environ["PATH"] = f"/opt/homebrew/bin:/usr/local/bin:{os.environ.get('PATH', '')}"

    setup_logging()

    # Fork: parent exits immediately, child runs the pipeline.
    try:
        pid = os.fork()
    except OSError as exc:
        sys.stderr.write(f"[session-summariser] fork failed ({exc}), running in foreground\n")
        pid = 0

    if pid > 0:
        sys.exit(0)

    os.setsid()
    try:
        _run_pipeline(hook_input)
    except Exception:
        log.exception("Summariser failed")
        sys.exit(1)
