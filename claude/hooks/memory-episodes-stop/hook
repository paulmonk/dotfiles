#!/usr/bin/env python3
"""SessionStop hook: summarise a Claude Code session into a memory episode.

Reads the Stop hook JSON from stdin (containing cwd, session_id,
and last_assistant_message), parses the session transcript,
calls Haiku for summarisation, and writes an episode .md file
into the Obsidian vault.

Forks a child process so the hook returns immediately without
blocking session close.
"""

from __future__ import annotations

import datetime as dt
import json
import logging
import os
import re
import subprocess
import sys
from collections import Counter
from pathlib import Path

MEMORY_DIR = Path.home() / "Documents" / "Personal" / "3-Claude-Sessions"
LOG_DIR = Path.home() / ".claude" / "logs" / "memory-episodes"

# Truncation limit for dialogue sent to Haiku.
MAX_DIALOGUE_CHARS = 80_000

log = logging.getLogger(__name__)


def setup_logging() -> None:
    """Configure file-based logging, falling back to stderr."""
    try:
        LOG_DIR.mkdir(parents=True, exist_ok=True)
        logging.basicConfig(
            filename=str(LOG_DIR / "summariser.log"),
            format="[%(asctime)s] %(message)s",
            datefmt="%Y-%m-%dT%H:%M:%S%z",
            level=logging.INFO,
        )
    except OSError:
        logging.basicConfig(
            stream=sys.stderr,
            format="[%(asctime)s] %(message)s",
            datefmt="%Y-%m-%dT%H:%M:%S%z",
            level=logging.INFO,
        )
        log.warning("Could not create log directory %s, logging to stderr", LOG_DIR)


def find_session_jsonl(cwd: str, *, session_id: str) -> Path | None:
    """Locate the Claude Code session JSONL for a given cwd and session.

    Args:
        cwd: The working directory from the session.
        session_id: The full session UUID.

    Returns:
        Path to the JSONL file, or None if it does not exist.
    """
    escaped = cwd.replace("/", "-").replace(".", "-")
    path = Path.home() / ".claude" / "projects" / escaped / f"{session_id}.jsonl"
    if path.is_file():
        return path
    return None


def parse_session(path: Path) -> tuple[str, Counter[str], str]:
    """Extract dialogue lines, tool use counts, and git branch.

    Args:
        path: Path to the session JSONL file.

    Returns:
        Tuple of (dialogue_text, tool_counter, branch).
    """
    lines: list[str] = []
    tools: Counter[str] = Counter()
    branch = ""

    skipped = 0
    with path.open() as f:
        for raw_line in f:
            stripped = raw_line.strip()
            if not stripped:
                continue
            try:
                entry = json.loads(stripped)
            except json.JSONDecodeError:
                skipped += 1
                continue

            entry_type = entry.get("type")
            if entry_type not in ("user", "assistant"):
                continue

            # Extract branch from first entry that has it.
            if not branch:
                branch = entry.get("gitBranch", "")

            msg = entry.get("message")
            if not msg or not isinstance(msg, dict):
                continue

            role = msg.get("role", "")
            content = msg.get("content", "")

            if role == "user" and isinstance(content, str) and content.strip():
                lines.append(f"Human: {content}")
            elif role == "assistant" and isinstance(content, list):
                for block in content:
                    btype = block.get("type", "")
                    if btype == "text":
                        text = block.get("text", "").strip()
                        if text:
                            lines.append(f"Assistant: {text}")
                    elif btype == "tool_use":
                        name = block.get("name", "unknown")
                        tools[name] += 1
                    # Skip thinking, tool_result, and other block types.

    if skipped:
        log.warning("Skipped %d malformed JSON lines in %s", skipped, path.name)

    return "\n".join(lines), tools, branch


def build_prompt(dialogue: str, *, tools: Counter[str], last_message: str = "") -> str:
    """Assemble the summarisation prompt for Haiku.

    Args:
        dialogue: Extracted human/assistant dialogue text.
        tools: Counter of tool names used in the session.
        last_message: The final assistant response from the Stop hook,
            used to give Haiku the session conclusion directly.

    Returns:
        Complete prompt string ready for Haiku.
    """
    truncated = dialogue[:MAX_DIALOGUE_CHARS]

    parts = [
        "Summarise this Claude Code conversation concisely.",
        "",
        "Start your response with a title line in exactly this format:",
        "Title: <short descriptive title, max 60 characters>",
        "",
        "Then provide the structured summary:",
        "",
        "## Goals",
        "What the user wanted to achieve.",
        "",
        "## Decisions",
        "Key choices made and their rationale.",
        "",
        "## Outcomes",
        "What was accomplished, what remains.",
        "",
        "Keep it under 300 words. Focus on decisions and rationale, "
        "not individual tool calls or code. Do not use emojis.",
    ]

    if tools:
        top_tools = ", ".join(f"{name} ({count})" for name, count in tools.most_common(10))
        parts.append("")
        parts.append(f"Tools used: {top_tools}")

    if last_message:
        parts.append("")
        parts.append("<final_response>")
        parts.append(last_message[:4000])
        parts.append("</final_response>")

    parts.append("")
    parts.append("<conversation>")
    parts.append(truncated)
    parts.append("</conversation>")

    return "\n".join(parts)


def call_haiku(prompt: str) -> str:
    """Send a prompt to Haiku via the Claude CLI and return the response.

    Args:
        prompt: The full prompt text.

    Returns:
        Haiku's response text, or empty string on failure.
    """
    # Strip CLAUDECODE to avoid nested-session detection when backgrounded.
    env = os.environ.copy()
    env.pop("CLAUDECODE", None)
    env["MAX_THINKING_TOKENS"] = "0"

    try:
        result = subprocess.run(
            [  # noqa: S607
                "claude",
                "-p",
                "--model",
                "haiku",
                "--no-session-persistence",
                "--tools",
                "",
                "--disable-slash-commands",
                "--setting-sources",
                "",
                "--system-prompt",
                "",
            ],
            input=prompt,
            capture_output=True,
            text=True,
            timeout=120,
            env=env,
            check=False,
        )
    except subprocess.TimeoutExpired:
        log.warning("claude timed out after 120s for summarisation")
        return ""
    if result.returncode != 0:
        log.warning("claude exited %d: %s", result.returncode, result.stderr[:500])
        return ""
    output = result.stdout.strip()
    if not output:
        log.warning("claude returned empty stdout for session summarisation")
    return output


def slugify(text: str) -> str:
    """Convert text to a lowercase, dash-separated filename slug."""
    slug = text.lower()
    # Normalise smart quotes and dashes to ASCII.
    slug = slug.replace("\u2018", "").replace("\u2019", "")
    slug = slug.replace("\u201c", "").replace("\u201d", "")
    slug = slug.replace("\u2013", "-").replace("\u2014", "-")
    slug = re.sub(r"[/\\:*?\"<>|'`,.()\[\]{}!;@#]", "", slug)
    slug = re.sub(r"[\s_]+", "-", slug)
    slug = re.sub(r"-{2,}", "-", slug)
    return slug.strip("-")


def parse_title(summary: str) -> tuple[str, str]:
    """Extract a Title: line from the start of the summary.

    Args:
        summary: Raw summary text from the LLM.

    Returns:
        Tuple of (title, remaining_summary). Title is empty string
        if no Title: line was found.
    """
    match = re.match(r"^Title:\s*(.+)", summary)
    if not match:
        return "", summary
    title = match.group(1).strip()
    if len(title) > 80:
        title = title[:80].rsplit(" ", 1)[0]
    rest = summary[match.end() :].lstrip("\n")
    return title, rest


PROJECTS_ROOT = Path.home() / "projects"


def derive_project(cwd: str) -> str:
    """Derive a project name from session cwd.

    For paths under ~/projects, returns up to two components
    (org/repo) so episodes group by organisation. Git worktrees
    are resolved to their main repo first via the `.git` file.

    Args:
        cwd: Working directory from the session.

    Returns:
        Project path string, or "_unknown" for unresolvable cases.
    """
    if not cwd or cwd == "/":
        return "_unknown"
    path = Path(cwd)

    # Resolve worktrees to their main repo root.
    git_marker = path / ".git"
    if git_marker.is_file():
        try:
            text = git_marker.read_text().strip()
            gitdir = text.removeprefix("gitdir:").strip()
            if "/.git/" in gitdir:
                path = Path(gitdir.split("/.git/")[0])
        except OSError as exc:
            log.warning("Could not read %s to resolve worktree: %s", git_marker, exc)

    # Under ~/projects: use up to 2 path components (org/repo).
    try:
        rel = path.relative_to(PROJECTS_ROOT)
        parts = rel.parts[:2]
        if parts:
            return str(Path(*parts))
    except ValueError:
        pass

    return path.name or "_unknown"


def write_episode(
    summary: str,
    *,
    title: str,
    project: str,
    cwd: str,
    session_id: str,
    branch: str,
    tools: Counter[str],
    now: dt.datetime,
) -> Path:
    """Write an episode markdown file with enriched frontmatter.

    Args:
        summary: The Haiku-generated summary text.
        title: Short descriptive title for the episode.
        project: Project name (basename of cwd).
        cwd: Working directory of the session.
        session_id: Full session UUID.
        branch: Git branch name, or empty string.
        tools: Counter of tool names used.
        now: Timestamp for the episode.

    Returns:
        Path to the written episode file.
    """
    project_dir = MEMORY_DIR / project
    project_dir.mkdir(parents=True, exist_ok=True)

    date_str = now.strftime("%Y-%m-%d")
    timestamp = now.strftime("%Y-%m-%dT%H:%M:%SZ")
    short_id = session_id[:7]
    heading = title or f"Conversation: {project}"

    slug = slugify(heading)
    if len(slug) > 80:
        slug = slug[:80].rsplit("-", 1)[0]
    filename = f"{date_str}-{slug}.md"

    # Avoid overwriting existing files.
    summary_file = project_dir / filename
    counter = 2
    while summary_file.exists():
        summary_file = project_dir / f"{date_str}-{slug}-{counter}.md"
        counter += 1

    fm_lines = [
        "---",
        f'title: "{heading}"',
        f"date: {timestamp}",
        f"project: {project}",
        f"directory: {cwd}",
        f"session_id: {short_id}",
    ]
    if branch:
        fm_lines.append(f"branch: {branch}")
    if tools:
        tool_names = sorted(tools)
        fm_lines.append(f"tools: [{', '.join(tool_names)}]")
    fm_lines.append("type: conversation")
    fm_lines.append("agent: claude")
    fm_lines.append("---")

    content = "\n".join(fm_lines) + f"\n\n# {heading}\n\n{summary}\n"
    summary_file.write_text(content)
    return summary_file


def _run_pipeline(hook_input: dict) -> None:
    """Run the summarisation pipeline from parsed hook input."""
    cwd = hook_input.get("cwd", "")
    session_id = hook_input.get("session_id", "")
    last_message = hook_input.get("last_assistant_message", "")

    if not cwd or not session_id:
        log.info("Missing cwd or session_id in hook input, skipping")
        return

    jsonl_path = find_session_jsonl(cwd, session_id=session_id)
    if not jsonl_path:
        log.info("No session JSONL for %s, skipping", session_id[:7])
        return

    dialogue, tools, branch = parse_session(jsonl_path)
    if not dialogue:
        log.info("No dialogue in %s, skipping", session_id[:7])
        return

    prompt = build_prompt(dialogue, tools=tools, last_message=last_message)
    summary = call_haiku(prompt)
    if not summary:
        log.warning("Summarisation returned empty for %s", session_id[:7])
        return

    title, summary = parse_title(summary)
    now = dt.datetime.now(dt.UTC)
    project = derive_project(cwd)

    episode = write_episode(
        summary,
        title=title,
        project=project,
        cwd=cwd,
        session_id=session_id,
        branch=branch,
        tools=tools,
        now=now,
    )
    log.info("Wrote episode %s", episode.name)


if __name__ == "__main__":
    # Read all input before forking (stdin closes with parent).
    raw = sys.stdin.read().strip()
    if not raw:
        sys.exit(0)

    try:
        hook_input = json.loads(raw)
    except json.JSONDecodeError as exc:
        sys.stderr.write(f"[memory-episodes-stop] invalid JSON from hook: {exc}\n")
        sys.exit(0)

    if not hook_input.get("session_id"):
        sys.exit(0)

    # Ensure brew binaries are on PATH for the child process.
    os.environ["PATH"] = f"/opt/homebrew/bin:/usr/local/bin:{os.environ.get('PATH', '')}"

    # Configure logging before forking so the child always has handlers.
    setup_logging()

    # Fork: parent exits immediately, child runs the pipeline.
    try:
        pid = os.fork()
    except OSError as exc:
        sys.stderr.write(f"[memory-episodes-stop] fork failed ({exc}), running in foreground\n")
        pid = 0

    if pid > 0:
        sys.exit(0)

    os.setsid()
    try:
        _run_pipeline(hook_input)
    except Exception:
        log.exception("Summariser failed")
        sys.exit(1)
